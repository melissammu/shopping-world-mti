{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/s/(.*)", "dest": "/api/og" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ]
}